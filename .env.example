DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/perfect_nails?schema=public"
NEXTAUTH_SECRET="replace-with-a-secure-random-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required in production for distributed rate limiting.
# Create an Upstash Redis database and copy its REST credentials.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Optional: used only by `npm run db:seed` to create the first admin user.
# Do not commit real production credentials.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Perfect Nails Admin"
SEED_ADMIN_PHONE=""
